# CoHomed Marketing Site Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://cohomed.com.au
NEXT_PUBLIC_APP_URL=https://app.cohomed.com.au

# Analytics - PostHog
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_API_HOST=https://app.posthog.com

# Analytics - Google Analytics 4
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Advertising - Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id

# Advertising - LinkedIn
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=your_linkedin_partner_id

# Email Service (optional)
NEXT_PUBLIC_EMAIL_API_KEY=your_email_api_key

# Optional: Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=false
